# Runner state (sessions, outputs, logs) — created next to the queue file.
# Current name plus legacy dot-prefixed names from older versions.
limitshift-*/
.limitshift-*/
.ai-runner-*/
.claude-runner-*/

# The user's real queue files (contain private prompts and local paths). Ignore both the
# new and legacy queue filenames by pattern, then re-include the shipped example + schema.
limitshift-queue*.json
ai-run-queue*.json
!limitshift-queue.example*.json
!limitshift-queue.schema.json
# Non-standard queue filenames (project-specific, contain local paths and private prompts)
limitshift-surgmesh*.json
limitshift-surgmesh*.tasklist.md
limitshift-surgmesh*.plan.md
career-ops_*.json

# Private local planning and predecessor scripts
run-gemini-phase1.ps1
phase1-automation-tasks.ps1
RELEASE-PLAN.md
copilot-integration-verify.md
# Working / scratch scripts not for the repo
apply-bash-changes*.ps1
run-all.ps1
limitshift.sh-rebuilt.sh

# Local docs (superpowers plans/specs — generated, not part of the public repo)
docs/superpowers/

# OS noise
Thumbs.db
.DS_Store
