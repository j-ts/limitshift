{
  "settings": {
    "stopOnError": false,
    "maxRunsPerTask": 7,
    "maxRetriesOnError": 4,
    "limitWaitMinutes": 11,
    "resetBufferMinutes": 1
  },
  "tasks": [
    {
      "name": "t1",
      "cli": "claude",
      "projectPath": ".",
      "model": "claude-sonnet-4-6",
