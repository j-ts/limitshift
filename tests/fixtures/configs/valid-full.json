    {
      "name": "t2",
      "cli": "codex",
      "projectPath": ".",
      "model": "gpt-5.4",
      "effort": "high",
      "prompt": "p2",
      "extraArgs": ["--sandbox", "workspace-write", "--skip-git-repo-check"]
    },
    {
      "name": "t3",
      "cli": "gemini",
      "projectPath": ".",
      "model": "gemini-2.5-pro",
      "effort": null,
      "prompt": "p3",
      "extraArgs": "--approval-mode yolo"
    }
  ]
}
