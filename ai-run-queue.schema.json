{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LimitShift config",
  "type": "object",
  "required": ["tasks"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stopOnError": { "type": "boolean", "default": true },
        "maxRunsPerTask": { "type": "integer", "minimum": 1, "default": 20 },
        "maxRetriesOnError": { "type": "integer", "minimum": 0, "default": 2 },
        "limitWaitMinutes": { "type": "integer", "minimum": 1, "default": 30 },
        "resetBufferMinutes": { "type": "integer", "minimum": 0, "default": 2 }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "cli", "projectPath", "prompt"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "cli": { "enum": ["claude", "codex", "gemini"] },
          "projectPath": { "type": "string", "minLength": 1 },
          "model": { "type": "string" },
          "effort": { "enum": ["low", "medium", "high"] },
          "prompt": { "type": "string", "minLength": 1 },
          "extraArgs": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          }
        }
      }
    }
  }
}
